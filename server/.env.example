# ── PoultryFarm Pro — Laravel API Environment ─────────────────────────────────
# Copy this to .env and fill in your values
# Never commit .env to version control

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="PoultryFarm Pro API"
APP_ENV=production         # local | production
APP_KEY=                   # Run: php artisan key:generate
APP_DEBUG=false            # NEVER true in production
APP_URL=https://api.greenvalley.farm

# ── Database (PostgreSQL 16) ───────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=poultry_farm_pro
DB_USERNAME=postgres
DB_PASSWORD=your-strong-password-here

# ── JWT Auth (tymon/jwt-auth) ──────────────────────────────────────────────────
# Run: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60                 # Token lifetime in minutes
JWT_REFRESH_TTL=20160      # Refresh token lifetime (14 days in minutes)
JWT_ALGO=HS256

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Angular frontend URL (no trailing slash)
FRONTEND_URL=https://poultry-farm-pro.vercel.app
FRONTEND_URL_PREVIEW=      # Optional: specific Vercel preview URL

# ── Queue (for async report generation) ────────────────────────────────────────
QUEUE_CONNECTION=database  # database | redis | sync
# For Redis (recommended for production):
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── File Storage (for report downloads) ─────────────────────────────────────────
FILESYSTEM_DISK=local      # local | s3
# For S3/R2 (recommended for production):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=poultry-farm-pro-reports

# ── Mail (for password reset) ────────────────────────────────────────────────
MAIL_MAILER=smtp           # smtp | ses | log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@greenvalley.farm
MAIL_FROM_NAME="PoultryFarm Pro"

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ── Cache ───────────────────────────────────────────────────────────────────
CACHE_STORE=database       # database | redis | file

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=error            # debug | info | warning | error
