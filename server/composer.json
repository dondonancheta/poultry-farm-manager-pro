{
  "name": "poultry-farm-pro/api",
  "description": "PoultryFarm Pro \u2014 Laravel 12 REST API",
  "type": "project",
  "require": {
    "php": "^8.2|^8.3|^8.4|^8.5",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "tymon/jwt-auth": "^2.1",
    "spatie/laravel-permission": "^6.0",
    "spatie/laravel-query-builder": "^6.0",
    "barryvdh/laravel-dompdf": "^3.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "phpunit/phpunit": "^11.0",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
    ],
    "dev": "php artisan serve --port=8000",
    "test": "php artisan test"
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  }
}