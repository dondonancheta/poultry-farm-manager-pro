{
  "name": "poultry-farm-pro-client",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "node --require ./crypto-polyfill.cjs node_modules/.bin/ng serve",
    "build": "node --require ./crypto-polyfill.cjs node_modules/.bin/ng build --configuration production",
    "build:dev": "node --require ./crypto-polyfill.cjs node_modules/.bin/ng build --configuration development",
    "api": "node mock-api/server.js",
    "dev": "concurrently --names \"API,NG\" --prefix-colors \"cyan,green\" \"npm run api\" \"npm run start\"",
    "postbuild": "echo Build complete"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.25",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@types/node": "^18.18.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "5.8.3",
    "concurrently": "^8.2.2"
  }
}